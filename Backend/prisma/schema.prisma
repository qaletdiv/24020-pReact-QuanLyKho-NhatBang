// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}
// @ts-ignore
datasource db {
  provider = "mysql" 
  url      = env("DATABASE_URL")
}
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]  @relation("UserOrders") // Quan hệ 1 - N với Order
}

// 2. Bảng Nhà cung cấp (Supplier)
// Mối quan hệ: Một Supplier có thể liên quan đến nhiều Order (1 - N)
model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  maCode    String   @unique @map("ma_code")
  sdt       String
  email     String
  address   String
  ghiChu    String?  @map("ghi_chu")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]  // Quan hệ 1 - N với Order
}

// 3. Bảng Sản phẩm (Product)
// Mối quan hệ: 
// - Nhiều Product thuộc về 1 ProductSize (N - 1)
// - Một Product có 1 Kho hàng Inventory (1 - 1)
// - Một Product xuất hiện trong nhiều OrderDetail (1 - N)
model Product {
  id           Int          @id @default(autoincrement())
  name         String
  maCode       String       @unique @map("ma_code")
  moTa         String?      @map("mo_ta")
  price        Float
  sizeId       Int          @map("size_id")
  inventoryId  Int          @unique @map("inventory_id")

  productSize  ProductSize  @relation(fields: [sizeId], references: [id])
  inventory    Inventory    @relation(fields: [inventoryId], references: [id])
  orderDetails OrderDetail[]
}

// 4. Bảng Kích thước sản phẩm (ProductSize)
// Mối quan hệ: 1 ProductSize có thể áp dụng cho nhiều Product (1 - N)
model ProductSize {
  id       Int       @id @default(autoincrement())
  size     String    @unique
  products Product[]
}

// 5. Bảng Đơn hàng (Order)
// Mối quan hệ: 
// - Thuộc về 1 Supplier (N - 1)
// - Được tạo bởi 1 User (N - 1)
// - Có nhiều chi tiết Đơn hàng OrderDetail (1 - N)
model Order {
  id          Int           @id @default(autoincrement())
  maCode      String        @unique @map("ma_code")
  supplierId  Int           @map("supplier_id")
  nguoiTao    Int           @map("nguoi_tao")
  ngayTao     DateTime      @default(now()) @map("ngay_tao")
  note        String?
  totalAmount Float         @map("total_amount")
  status      String        @default("pending")

  supplier    Supplier      @relation(fields: [supplierId], references: [id])
  creator     User          @relation("UserOrders", fields: [nguoiTao], references: [id])
  orderDetails OrderDetail[]
}

// 6. Bảng Chi tiết đơn hàng (OrderDetail)
// Mối quan hệ: Nối giữa Order và Product (N - 1 với cả hai)
model OrderDetail {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  productId   Int      @map("product_id")
  quantity    Int
  price       Float
  totalAmount Float    @map("total_amount")

  order       Order    @relation(fields: [orderId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

// 7. Bảng Tồn kho (Inventory)
// Mối quan hệ: 
// - 1 - 1 với Product
// - 1 - N với Lịch sử giao dịch kho (InventoryTransaction)
model Inventory {
  id                Int                    @id @default(autoincrement())
  quantity          Int
  capNhatLanNhat    DateTime               @updatedAt @map("cap_nhat_lan_nhat")
  hangDatTruoc      Int                    @default(0) @map("hang_dat_truoc")
  availableQuantity Int                    @map("available_quantity") // Bạn sẽ tự tính toán giá trị này (quantity - hangDatTruoc) trước khi lưu vào DB

  product           Product?
  transactions      InventoryTransaction[]
}

// 8. Bảng Lịch sử giao dịch kho (InventoryTransaction)
// Mối quan hệ: Nhiều lịch sử thuộc về 1 kho hàng Inventory (N - 1)
model InventoryTransaction {
  id          Int      @id @default(autoincrement())
  inventoryId Int      @map("inventory_id")
  type        String   // Ví dụ: "IMPORT" (Nhập), "EXPORT" (Xuất), "ADJUST" (Điều chỉnh)
  quantity    Int      // Số lượng thay đổi (+ hoặc -)
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  inventory   Inventory @relation(fields: [inventoryId], references: [id])
}
